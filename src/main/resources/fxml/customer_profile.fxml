<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.controller.fx.CustomerProfileController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="50.0" layoutY="50.0" spacing="20.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
         <children>
            <Label styleClass="header-text" text="My Profile" />
            
            <GridPane hgap="20.0" vgap="15.0" styleClass="card">
               <children>
                  <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="nameField" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  
                  <Label text="Email Address:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextField fx:id="emailField" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <Label text="Phone Number:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <TextField fx:id="phoneField" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                  <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                  <TextField fx:id="addressField" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  
                  <Label text="Birthday:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <DatePicker fx:id="birthdayPicker" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  
                  <Label text="Identity Card:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                  <TextField fx:id="idCardField" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  
                  <Label text="License Number:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                  <TextField fx:id="licenseField" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />

               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </GridPane>
            
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleSave" styleClass="button-primary" text="Save Changes" />
                  <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="button-primary" style="-fx-background-color: -fx-secondary-color;" text="Undo Changes" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
            
            <Label fx:id="statusLabel" textFill="#2ecc71" visible="false" />
         </children>
      </VBox>
   </children>
</AnchorPane>
