<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1100.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.controller.fx.CustomerDashboardController">
   <left>
      <VBox prefWidth="250.0" styleClass="dashboard-sidebar" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" prefHeight="150.0" spacing="10.0">
               <children>
                  <Label text="Car Rental" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <Label fx:id="customerNameLabel" text="Welcome!" textFill="#bdc3c7" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Button fx:id="btnBooking" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleBooking" styleClass="sidebar-button" text="Book a Car" />
                  <Button fx:id="btnHistory" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleRentalHistory" styleClass="sidebar-button" text="My Rentals" />
                  <Button fx:id="btnProfile" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleProfile" styleClass="sidebar-button" text="My Profile" />
               </children>
               <padding>
                  <Insets top="20.0" />
               </padding>
            </VBox>
            <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-button" text="Logout" textFill="#e74c3c" />
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="mainContentArea" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <!-- Content will be loaded here -->
         <children>
            <VBox alignment="CENTER" layoutX="200.0" layoutY="200.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <Label text="Welcome to Car Rental System" styleClass="header-text" />
                  <Label text="Select an option from the sidebar to get started." textFill="#7f8c8d" />
                  <HBox alignment="CENTER" spacing="20.0">
                     <children>
                        <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" styleClass="card">
                           <children>
                               <Label text="Ready to drive?" styleClass="sub-header-text" />
                               <Button fx:id="btnBrowseCars" mnemonicParsing="false" onAction="#handleBooking" styleClass="button-primary" text="Browse Cars">
                                 <VBox.margin>
                                    <Insets top="20.0" />
                                 </VBox.margin>
                              </Button>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </center>
</BorderPane>
