<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.controller.fx.CustomerManagementController">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="header-text" text="Customer Management" />
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <TextField fx:id="searchField" prefWidth="250.0" promptText="Search by name or email" styleClass="text-field" />
                  <Button mnemonicParsing="false" onAction="#handleSearch" styleClass="button-primary" text="Search" />
               </children>
            </HBox>
            
            <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colID" prefWidth="50.0" text="ID" />
                  <TableColumn fx:id="colName" prefWidth="150.0" text="Name" />
                  <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
                  <TableColumn fx:id="colMobile" prefWidth="100.0" text="Mobile" />
                  <TableColumn fx:id="colBirthday" prefWidth="100.0" text="Birthday" />
                  <TableColumn fx:id="colLicence" prefWidth="120.0" text="Licence #" />
               </columns>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleAdd" styleClass="button-primary" style="-fx-background-color: -fx-success-color;" text="Add New" />
                  <Button mnemonicParsing="false" onAction="#handleEdit" styleClass="button-primary" text="Edit Selected" />
                  <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="button-primary" style="-fx-background-color: -fx-danger-color;" text="Delete" />
                  <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="button-primary" style="-fx-background-color: -fx-secondary-color;" text="Refresh" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
