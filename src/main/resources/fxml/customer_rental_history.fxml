<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.controller.fx.CustomerRentalHistoryController">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label fx:id="historyHeader" styleClass="header-text" text="My Rental History" />
            
            <TableView fx:id="rentalTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colCar" prefWidth="200.0" text="Car Name" />
                  <TableColumn fx:id="colPickupDate" prefWidth="120.0" text="Pickup Date" />
                  <TableColumn fx:id="colReturnDate" prefWidth="120.0" text="Return Date" />
                  <TableColumn fx:id="colPrice" prefWidth="120.0" text="Total Price" />
                  <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
               </columns>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" styleClass="button-primary" style="-fx-background-color: -fx-danger-color;" text="Cancel Rental" />
                  <Button fx:id="btnReturn" mnemonicParsing="false" onAction="#handleReturn" styleClass="button-primary" text="Request Return" />
                  <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="button-primary" style="-fx-background-color: -fx-secondary-color;" text="Refresh" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
