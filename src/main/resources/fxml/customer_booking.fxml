<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.controller.fx.CustomerBookingController">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="header-text" text="Book a Car" />
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <Label text="From:" />
                  <DatePicker fx:id="startDatePicker" prefWidth="130.0" />
                  <Label text="To:" />
                  <DatePicker fx:id="endDatePicker" prefWidth="130.0" />
                  <Button mnemonicParsing="false" onAction="#handleSearch" styleClass="button-primary" text="Search Available" />
               </children>
            </HBox>
            
            <TableView fx:id="carTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colName" prefWidth="200.0" text="Car Name" />
                  <TableColumn fx:id="colModel" prefWidth="120.0" text="Model Year" />
                  <TableColumn fx:id="colColor" prefWidth="100.0" text="Color" />
                  <TableColumn fx:id="colCapacity" prefWidth="100.0" text="Capacity" />
                  <TableColumn fx:id="colPrice" prefWidth="150.0" text="Daily Rate" />
               </columns>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Label fx:id="statusLabel" textFill="#2ecc71" visible="false" />
                  <Button mnemonicParsing="false" onAction="#handleBook" styleClass="button-primary" style="-fx-background-color: -fx-success-color;" text="Book Selected Car" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
