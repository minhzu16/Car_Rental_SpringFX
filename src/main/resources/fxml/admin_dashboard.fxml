<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1100.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.controller.fx.AdminDashboardController">
   <left>
      <VBox prefWidth="250.0" styleClass="dashboard-sidebar" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" prefHeight="150.0" spacing="10.0">
               <children>
                  <Label text="Admin Control" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <Label fx:id="adminNameLabel" text="Administrator" textFill="#bdc3c7" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Button alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-button" text="Overview" />
                  <Button fx:id="btnCustomers" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleCustomerManagement" styleClass="sidebar-button" text="Customer Management" />
                  <Button fx:id="btnCars" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleCarManagement" styleClass="sidebar-button" text="Car Management" />
                  <Button fx:id="btnRentals" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleRentalManagement" styleClass="sidebar-button" text="Rental Transactions" />
                  <Button fx:id="btnReports" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#handleReports" styleClass="sidebar-button" text="Rental Reports" />
               </children>
               <padding>
                  <Insets top="20.0" />
               </padding>
            </VBox>
            <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-button" text="Logout" textFill="#e74c3c" />
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="mainContentArea" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox layoutX="40.0" layoutY="40.0" spacing="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.topAnchor="40.0">
               <children>
                  <Label text="System Overview" styleClass="header-text" />
                  <HBox spacing="30.0">
                     <children>
                        <VBox prefHeight="120.0" prefWidth="200.0" styleClass="card">
                           <children>
                              <Label text="Total Customers" textFill="#7f8c8d" />
                              <Label fx:id="totalCustomersLabel" text="0" textFill="#2c3e50">
                                 <font>
                                    <Font name="System Bold" size="36.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <VBox prefHeight="120.0" prefWidth="200.0" styleClass="card">
                           <children>
                              <Label text="Total Cars" textFill="#7f8c8d" />
                              <Label fx:id="totalCarsLabel" text="0" textFill="#2c3e50">
                                 <font>
                                    <Font name="System Bold" size="36.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <VBox prefHeight="120.0" prefWidth="200.0" styleClass="card">
                           <children>
                              <Label text="Active Rentals" textFill="#7f8c8d" />
                              <Label fx:id="activeRentalsLabel" text="0" textFill="#2c3e50">
                                 <font>
                                    <Font name="System Bold" size="36.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <VBox prefHeight="350.0" prefWidth="800.0" styleClass="card">
                     <children>
                         <Label text="Recent Activities" styleClass="sub-header-text" />
                         <!-- Placeholder for activity list -->
                         <Label text="No recent activities to show." textFill="#bdc3c7">
                             <VBox.margin>
                                 <Insets top="20.0" />
                             </VBox.margin>
                         </Label>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </center>
</BorderPane>
